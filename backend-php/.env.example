# Crea8iv PatientFlow API environment
# Copy to .env and fill in. Generate secrets with:
#   php -r "echo bin2hex(random_bytes(32)), PHP_EOL;"

APP_ENV=production
APP_TIMEZONE=Asia/Karachi

# Database: mysql (production) or sqlite (development)
DB_DRIVER=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=
DB_USER=
DB_PASS=
# DB_PATH=/path/to/dev.db   # only for sqlite

# REQUIRED — API will not boot without these
JWT_SECRET=
JWT_REFRESH_SECRET=
JWT_EXPIRES_IN=900
JWT_REFRESH_EXPIRES_IN=604800

# Allowed frontend origin
CLIENT_URL=https://portal.example.com
WEBSITE_URL=https://www.example.com
PORTAL_HOST=portal.example.com

# Authentication throttling and reset-link lifetime (seconds)
LOGIN_MAX_ATTEMPTS_EMAIL=5
LOGIN_MAX_ATTEMPTS_IP=20
PASSWORD_RESET_TTL=1800

# Email (password resets, notifications). If SMTP_HOST is empty,
# emails are written to backend-php/logs/mail.log instead (dev mode).
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
MAIL_FROM=no-reply@crea8ivpatientflow.com
MAIL_FROM_NAME=Crea8iv PatientFlow

# Optional Twilio (legacy WhatsApp sandbox)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# REQUIRED when the Meta WhatsApp webhook is enabled. Found under
# Meta App Dashboard > App settings > Basic > App secret.
META_APP_SECRET=

# Tenant AI keys are disabled by default; platform-managed keys are preferred.
ALLOW_CLINIC_AI_KEYS=0

# Custom domains currently use the manual Hostinger/hPanel SSL workflow.
# The Cloudflare provider is a code stub and must not be enabled in production.
SSL_PROVIDER=manual
# CF_API_TOKEN=
# CF_ZONE_ID=

# Backup retention and optional off-site rsync/scp destination
BACKUP_RETENTION_DAYS=14
BACKUP_REMOTE=
